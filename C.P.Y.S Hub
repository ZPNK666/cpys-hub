<script>
// ====== CLOCK ======
setInterval(() => {
  const n = new Date();
  document.getElementById('clock').textContent =
    n.toTimeString().slice(0,8);
}, 1000);

// ====== PLATFORM SWITCH ======
function switchPlatform(p, el) {
  document.querySelectorAll('.plat-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.content').forEach(c => c.classList.remove('show'));
  document.getElementById('content-' + p).classList.add('show');
}

// ====== SUB TAB HELPERS ======
function switchTab(tabs, contents, key, el) {
  tabs.querySelectorAll('.inv-slot').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  contents.forEach(c => c.classList.remove('show'));
  document.getElementById(key).classList.add('show');
}

function mcTab(k, el) {
  switchTab(
    document.getElementById('mc-tabs'),
    document.querySelectorAll('[id^="mc-tab-"]'),
    'mc-tab-' + k, el
  );
}

function dsTab(k, el) {
  switchTab(
    document.getElementById('ds-tabs'),
    document.querySelectorAll('[id^="ds-tab-"]'),
    'ds-tab-' + k, el
  );
}

// ====== COUNTER ANIMATION ======
function animCount(el, target) {
  let s = 0, dur = 1000, start = null;
  const step = ts => {
    if (!start) start = ts;
    const p = Math.min((ts - start) / dur, 1);
    el.textContent = Math.floor(p * p * target);
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = target;
  };
  requestAnimationFrame(step);
}

