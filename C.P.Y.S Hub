  // Media grid
  const mediaTypes = [
    {key:'images',   icon:'🖼️', label:'Картинки',  total: dsMembers.reduce((s,m)=>s+m.images,0)},
    {key:'gifs',     icon:'🎞️', label:'Гифки',     total: dsMembers.reduce((s,m)=>s+m.gifs,0)},
    {key:'stickers', icon:'😄', label:'Стикеры',   total: dsMembers.reduce((s,m)=>s+m.stickers,0)},
    {key:'voiceMsgs',icon:'🎤', label:'Голосовые', total: dsMembers.reduce((s,m)=>s+m.voiceMsgs,0)},
    {key:'msgs',     icon:'💬', label:'Текст',      total: dsMembers.reduce((s,m)=>s+m.msgs,0)},
    {key:'files',    icon:'📁', label:'Файлы',      total: dsMembers.reduce((s,m)=>s+m.files,0)},
  ];

  document.getElementById('ds-media-grid').innerHTML = mediaTypes.map((mt,i) => `
    <div class="media-card${i===0?' active':''}" onclick="showMediaDetail('${mt.key}','${mt.label}',this)">
      <span class="m-icon">${mt.icon}</span>
      <span class="m-label">${mt.label}</span>
      <span class="m-count">${mt.total}</span>
    </div>`).join('');

  showMediaDetail('images','Картинки', document.querySelector('.media-card'));

  // Members list
  document.getElementById('ds-member-list').innerHTML = dsMembers.map(m => `
    <div class="player-row">
      <div class="blink-dot" style="background:${m.status==='online'?'var(--emerald)':'#444'};box-shadow:none;flex-shrink:0"></div>
      <div class="player-head" style="background:${m.color}22;border-color:${m.color}88;border-radius:50%">${m.name[0]}</div>
      <div class="player-name-wrap">
        <div class="player-name">${m.name} <span class="mc-tag ${m.role}">${m.role.toUpperCase()}</span></div>
        <div class="player-sub">${m.msgs} сообщений сегодня</div>
      </div>
      <div class="player-time" style="color:${m.status==='online'?'var(--emerald)':'#444'}">${m.status==='online'?'ONLINE':'OFFLINE'}</div>
    </div>`).join('');

  // Join/Leave log
  document.getElementById('ds-jl-log').innerHTML = jlLog.map(r => `
    <div class="jl-row">
      <span>${r.ev==='join'?'➕':'➖'}</span>
      <span class="jl-name ${r.ev==='join'?'jl-join':'jl-leave'}">${r.name}</span>
      <span class="jl-time">${r.time}</span>
      <span style="font-size:13px;color:#555">${r.ev==='join'?'вошёл':'вышел'}</span>
    </div>`).join('');

  // Join/Leave top
  document.getElementById('ds-jl-top').innerHTML = jlTop.map((u,i) => `
    <div class="player-row">
      <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:#555;width:20px">#${i+1}</span>
      <div class="player-name-wrap">
        <div class="player-name">${u.name}</div>
        <div class="player-sub">Входов: ${u.joins} · Выходов: ${u.leaves}</div>
      </div>
    </div>`).join('');

  // Roles
  const roles = [
    {name:'👑 Администраторы', count:3,  max:157, color:'var(--redstone)'},
    {name:'🛡️ Модераторы',     count:7,  max:157, color:'var(--gold)'},
    {name:'💎 VIP',            count:24, max:157, color:'var(--diamond)'},
    {name:'🟢 Участники',      count:123,max:157, color:'#7289da'},
  ];
  document.getElementById('ds-roles').innerHTML = roles.map(r => `
    <div class="prog-wrap">
      <div class="prog-info">
        <span>${r.name}</span>
        <span style="color:#555">${r.count} чел.</span>
      </div>
      <div class="prog-bar">
        <div class="prog-fill" style="width:${Math.round(r.count/r.max*100)}%;--c:${r.color}"></div>
      </div>
    </div>`).join('');

  // DS Ticker
  const dsti = [
    ['ProGamer_07 написал 143 сообщения',true],['Новый участник QuickStar',true],
    ['Boost x3 — сервер получил бонус',true],['CoolDude99 покинул сервер',false],
    ['Активность +34%',true],['ModerX выдал роль VIP',true],
  ];
  document.getElementById('ds-ticker').innerHTML = [...dsti,...dsti].map(([t,g]) =>
    `<span class="ticker-item${g?'':' bad'}"><b>${t}</b></span>`).join('');
}

// Media detail
function showMediaDetail(key, label, el) {
  document.querySelectorAll('.media-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('ds-media-panel-title').textContent = `КТО ОТПРАВЛЯЛ — ${label.toUpperCase()}`;

  const keyMap = {images:'images',gifs:'gifs',stickers:'stickers',voiceMsgs:'voiceMsgs',msgs:'msgs',files:'files'};
  const sorted = [...dsMembers].filter(m => m[keyMap[key]] > 0).sort((a,b) => b[keyMap[key]] - a[keyMap[key]]);

  document.getElementById('ds-media-detail').innerHTML = sorted.length ? sorted.map((m,i) => `
    <div class="player-row">
      <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:#555;width:20px">#${i+1}</span>
      <div class="player-head" style="background:${m.color}22;border-color:${m.color}88">${m.name[0]}</div>
      <div class="player-name-wrap"><div class="player-name">${m.name}</div></div>
      <div class="player-time">${m[keyMap[key]]} шт.</div>
    </div>`).join('') : '<div style="color:#555;padding:8px">Нет данных</div>';
}

// ====== INIT ======
renderMC();
renderDS();

// Live flicker MC online
setInterval(() => {
  const el = document.getElementById('mc-online');
  const v = parseInt(el.textContent) || 0;
  const d = Math.random() > 0.6 ? 1 : Math.random() > 0.6 ? -1 : 0;
  if (v + d >= 0) el.textContent = v + d;
}, 5000);

// ====== LOAD REAL DATA from discord_stats.json ======
async function loadRealData() {
  try {
    const r = await fetch('discord_stats.json');
    if (!r.ok) return;
    const d = await r.json();
    if (d.summary) {
      document.getElementById('ds-total').textContent  = d.summary.total_members  || 0;
      document.getElementById('ds-online').textContent = d.summary.online_count   || 0;
      document.getElementById('ds-msgs').textContent   = d.summary.messages_today || 0;
      document.getElementById('ds-voice-sub').textContent = `в голосе: ${d.summary.in_voice_count || 0}`;
      document.getElementById('ds-m-badge').textContent   = `${d.summary.online_count || 0} онлайн`;
      document.getElementById('ds-voice-badge').textContent = `${d.summary.in_voice_count || 0} в голосе`;
    }
    console.log('✅ Данные Discord загружены из discord_stats.json');
  } catch(e) {
    // нет файла — работаем на тестовых данных
  }
}
loadRealData();
setInterval(loadRealData, 30000); // обновлять каждые 30 сек
</script>
</body>
</html>
